# Set alias if executable exists on PATH
alias_if_exists() {
  command -v "$1" >/dev/null 2>&1 && alias "$2"="$3"
}

alias_if_exists clear c "clear"
alias_if_exists cyme lsusb "cyme"
alias_if_exists rg grep "rg"
alias_if_exists eza ls "eza"
alias_if_exists bat cat "bat -p --theme ansi"

# AI is aligned do not worry
alias_if_exists codex codex "codex --dangerously-bypass-approvals-and-sandbox"
alias_if_exists claude claude "claude --dangerously-skip-permissions"
